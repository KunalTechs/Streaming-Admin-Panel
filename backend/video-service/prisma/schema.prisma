generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id
  username  String   @unique
  email     String   @unique
  createdAt DateTime @default(now())
  videos    Video[]
}

model Video {
  id           String   @id @default(uuid())
  title        String
  description  String?  @db.Text
  url          String
  hlsUrl       String?
  filename     String
  thumbnailUrl String?
  isProcessed  Boolean  @default(false)
  status       Status   @default(PENDING)
  views        Int      @default(0)
  categoryId   String? // Links to category service via UUId string
  authorId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  adminDeletedAt   DateTime? //track the deletion date
  author       Admin    @relation(fields: [authorId], references: [id])
 

  @@index([authorId])
  @@index([categoryId])
}

enum Status {
  PENDING
  PROCESSING
  READY
  FAILED
}
